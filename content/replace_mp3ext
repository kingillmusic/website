#!/bin/sh

# fix_audio_ext.sh – Replace .mp3 with .opus on line 10 of all beats/*.md files
# Run this script from the directory that contains the beats/ folder.

target_dir="./beats"

if [ ! -d "$target_dir" ];then
    echo "Error: Directory '$target_dir' not found." >&2
    exit 1
fi

# Loop over every .md file in beats/
for file in "$target_dir"/*.md; do
    [ -f "$file" ] || continue

    echo "Processing $file ..."

    # Create a temporary file
    tmp="${file}.tmp"

    # Use sed to replace '.mp3' with '.opus' only on line 10
    # If the file has fewer than 10 lines, nothing is changed.
    sed '10 s/\.mp3/\.opus/g' "$file" > "$tmp"

    # Check if the temporary file is different from the original
    if cmp -s "$file" "$tmp"; then
        echo "  No change needed (line 10 may not exist or already uses .opus)."
        rm -f "$tmp"
    else
        # Replace the original with the modified version
        mv "$tmp" "$file"
        echo "  Updated: replaced .mp3 with .opus on line 10."
    fi
done

echo "All files processed."
/* CSS for anything related to the music functionality */

.row
{
/*	display: grid; */
/*	grid-template-columns: repeat(auto-fit, minmax(336px, 1fr));*/
/*	grid-template-columns: none;*/
	width: 100%;
	scroll-margin-top: 3.3em;
	border: 4px solid black;
	border-radius: 2px;
	margin: 10px;

}

.row > div
{
	display: flex;
	cursor: pointer;
	align-items: center;
	justify-content: space-between;
}

.Track 
{
	background: #eeeeee;
	gap: 10px;
}

.TrackPlay
{
	max-height: 1.2em ;
}

.TrackTitle
{
	font-size: 90%;
	text-transform: uppercase;
	font-weight: 700;
}

.waveform-per-track {
   height: 100px;          /* adjust as needed */
	width: 100%;
	border-radius: 4px;
}

.track-waveform {
	width: 100%;
	height: 100%;
	border-radius: 4px;
}

#MusicPlayer > div, #SinglePlayer > div
{
	display: flex ;
	justify-content: space-around;
	align-items: center;
	position: fixed;
	width: 95% 
}

#PlayerControls, #SingleControls
{
	border-radius: 8px;
	bottom: 0;
	left: 50%;
	transform: translate(-50%, -50%) ;
	background: #97ffff;
}

#PlayerPlay, #Next, #Previous, #Seek5, #Seek15, #Shuffle, #Repeat
{
	border-radius: 50%;
	background: #97ffff;
}

#PlayerPlay
{
	max-height: 2.5em
}

#Next, #Previous
{
	max-height: 1.8em ;
}

#Duration, #SingleDuration
{
}

#StartDuration, #EndDuration, #StartSingle, #EndSingle, #Seek5, #Seek15
{
	font-size: 0.6em ;
} #EndDuration { display: none }

#Five, #Fifteen, #Shuffle, #Repeat { max-height: 1.2em }

@media only screen and (min-width: 700px)
{
	.row
	{
		display: grid;
		grid-template-columns: none;
		width: unset;
	}
	#MusicPlayer > div, #SinglePlayer > div
	{
		width: 40%;
	}
}

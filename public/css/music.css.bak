/* CSS for anything related to the music functionality */

.row
{
    display: flex ;
	align-items: center;
	flex-wrap: wrap;
	gap: 10px;
	margin-bottom: 2rem ;
	scroll-margin-top: 3em ;
	}

.row > div
{
	cursor: pointer ;
}

.Track
{
	 display: flex;
	 align-items: center;
	flex-wrap: wrap;
	 flex: 1;
	white-space: nowrap ;
}

.TrackPlay
{
	white-space: nowrap;
	max-height: 1.2em ;
}

.TrackTitle
{
	font-weight: bold ;
	margin-left: 1.5em ;
}

.waveform-per-track {
    /*width: 70vw;*/
	height: 100px;          /* adjust as needed */
	width: 75%;
	border-radius: 4px;
}

.track-waveform {
	width: 100%;
	height: 100%;
	border-radius: 4px;
}

.TrackMenu
{
	color: #87ffff ;
	padding: 0 1rem ;
	flex-shrink: 0;
}

#MusicPlayer, #SinglePlayer
{
    bottom: 0 ;
    width: 100% ;
    display: flex ;
    position: fixed ;
    padding-bottom: 4vmax ;
    background-image: url('/img/fond.png') ;
}

#MusicPlayer > div { width: 100% }
#SinglePlayer > div { width: 100% }

#PlayerControls, #SingleControls
{
    display: flex ;
	align-items: center ;
	justify-content: space-evenly
}

#PlayerPlay, #Next, #Previous, #Seek5, #Seek15, #GotoTrack, #Shuffle
{
    cursor: pointer ;
	transition: all 0.1s ease
}

#PlayerPlay
{
	padding: 1% ;
	max-height: 2.8em
}

#Next, #Previous
{
	padding: 1% ;
	max-height: 1.8em ;
}

#Duration, #SingleDuration
{
    display: flex ;
    margin: 0 -1em ;
    align-items: center ;
    justify-content: space-evenly ;
}

#StartDuration, #EndDuration, #StartSingle, #EndSingle, #Seek5, #Seek15
{
    font-size: 75% ;
 	color: #87ffff ;
}

#Five, #Fifteen, #Shuffle, #Repeat { max-height: 1.2em }

@media only screen and (min-width: 400px)
{
    .Lease img { max-height: 2rem }
    /* .TrackPlay { max-height: 1.2em } */
}

@media only screen and (min-width: 600px) { #Duration, #SingleDuration { margin: 0 3em } }

@media only screen and (min-width: 1000px)
{
    #MusicPlayer { padding-bottom: 2vmax; background: none ; justify-content: space-evenly }
    #SinglePlayer { padding-bottom: 2vmax; background-image: url('/img/fond.png') }
    #Duration, #SingleDuration { margin: 0 10em }
    #PlayerControls, #SingleControls { margin: 0 10em }
    .Track > div { scroll-margin-top: 3.5em }
}
